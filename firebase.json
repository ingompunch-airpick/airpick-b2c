{
  "hosting": {
    "site": "airpick-b2c",
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "/robots.txt",
        "headers": [
          {
            "key": "Content-Type",
            "value": "text/plain; charset=utf-8"
          }
        ]
      },
      {
        "source": "/shared/**",
        "headers": [
          {
            "key": "Access-Control-Allow-Origin",
            "value": "*"
          },
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/receipt",
        "function": {
          "functionId": "getReceipt",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/api/reservation-lookup",
        "function": {
          "functionId": "lookupReservation",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/api/reservation-cancel",
        "function": {
          "functionId": "cancelReservation",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": ["node_modules", ".git", "firebase-debug.log", "firebase-debug.*.log", "*.local"]
    }
  ]
}
