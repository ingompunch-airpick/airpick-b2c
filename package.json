{
  "name": "airpick-b2c",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run sync:airlines && vite",
    "build": "npm run guides && npm run partners && npm run sitemap && npm run sync:airlines && tsc -b && vite build",
    "lint": "tsc -b --noEmit",
    "guides": "node scripts/generate-guides.mjs",
    "partners": "node scripts/generate-partners.mjs",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "sync:airlines": "cp src/constants/airlines.json public/shared/airlines.json",
    "sync:esim": "node scripts/sync-esim-offers.mjs",
    "sync:parking": "node scripts/sync-parking.mjs",
    "preview": "vite preview",
    "deploy:hosting": "npm run sync:esim && npm run sync:parking && npm run build && npx -y firebase-tools@latest deploy --only hosting:airpick-b2c",
    "deploy:functions": "cd functions && npm run build && cd .. && npx -y firebase-tools@latest deploy --only functions",
    "deploy:hosting:preview": "npm run sync:esim && npm run sync:parking && npm run build && npx -y firebase-tools@latest hosting:channel:deploy preview --site airpick-b2c --expires 7d",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:open": "npx cap open android",
    "android:bundle:debug": "cd android && ./gradlew bundleDebug",
    "android:bundle:release": "cd android && ./gradlew bundleRelease",
    "android:aab": "bash scripts/build-android-aab.sh",
    "deploy:rules": "echo 'ERROR: Firestore rules는 airpick2-b-to-b에서만 배포하세요.' && exit 1"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/splash-screen": "^8.0.1",
    "clsx": "^2.1.1",
    "firebase": "^12.14.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/navermaps": "^3.9.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0"
  }
}
