# Firebase Functions — 카카오 알림톡 (로컬 에뮬레이터용)
KAKAO_ALIMTALK_ENABLED=true
KAKAO_ALIMTALK_API_URL=https://api-alimtalk.cloud.toast.com/alimtalk/v2.3/appkeys/YOUR_APPKEY/messages
KAKAO_ALIMTALK_APP_KEY=your-secret-key

KAKAO_SENDER_KEY=your-airpick-sender-key
KAKAO_SENDER_KEY_PARTNER=your-partner-sender-key

KAKAO_TEMPLATE_AIRPICK_B2C=에어픽_예약접수_템플릿코드
KAKAO_TEMPLATE_PARTNER_HOMEPAGE=제휴사_예약접수_템플릿코드

# 템플릿 변수 예시 (카카오에 등록한 이름과 동일해야 함)
# #{고객명} #{업체명} #{차량번호} #{출국일} #{출국시간} #{참고요금} #{브랜드} #{접수증링크}

# 접수증 페이지 (PUBLIC_SITE_ORIGIN)
PUBLIC_SITE_ORIGIN=https://airpick-b2c.web.app
