# Firebase Functions params (로컬/배포용). secrets는 Firebase Secret Manager 사용.
PUBLIC_SITE_ORIGIN=https://airpick-b2c.web.app
# 공공데이터포털 일반 인증키(Decoding) — Secret Manager: DATA_GO_KR_SERVICE_KEY
# DATA_GO_KR_SERVICE_KEY=

# 네이버 클라우드 Maps (Geocoding · Directions) — Secret: NAVER_NCP_API_KEY_ID / NAVER_NCP_API_KEY
# 콘솔 Application의 Client ID · Client Secret (Directions·Geocoding API 사용 설정 필요)
# NAVER_NCP_API_KEY_ID=
# NAVER_NCP_API_KEY=
